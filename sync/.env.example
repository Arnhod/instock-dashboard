# sync/.env.example — Instock WMS Sync Job
# Kopier til sync/.env og fyll inn verdier
# ALDRI commit sync/.env til Git

# ── Azure SQL (Instock) ──────────────────────────────────
DB_SERVER=your-server.database.windows.net
DB_PORT=3342
DB_NAME=your-database-name
DB_USER=your-db-user
DB_PASSWORD=your-password

# ── Supabase ─────────────────────────────────────────────
# Finn disse i Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://DIN-PROJECT-ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Kundekonfigurasjon ───────────────────────────────────
CUSTOMER_NAME=Kundenavn AS
CUSTOMER_SHORT=KUNDE
CUSTOMER_COLOR=#4f6ef7

# Warehouse-filter: tom = alle lagre, tall = filtrer på ett WAREHOUSE_ID
WAREHOUSE_ID=

# Soner som JSON-array (id, name, color, hot)
ZONES_JSON=[{"id":"ZONE_A","name":"Zone A","color":"#f5c518","hot":true},{"id":"ZONE_B","name":"Zone B","color":"#f97316","hot":true},{"id":"ZONE_C","name":"Zone C","color":"#22c55e","hot":false},{"id":"ZONE_D","name":"Zone D","color":"#3b82f6","hot":false}]

# Produkt-statuser som er "kalde" (flytt ut av hot zone)
COLD_STATUS_IDS=2,6,9,12

# Systemplasseringer (ikke fysiske hylleplasser)
SYSTEM_LOCATIONS=MOTTAK,Bermuda,REKLAMASJON,EOL
